{
  "name": "@softwarity/nestjs-amqp",
  "version": "0.3.0",
  "description": "AMQP 1.0 integration for NestJS, powered by rhea. Decorator-based publishers and consumers, RxJS-friendly, with optional DLQ browser.",
  "keywords": [
    "nestjs",
    "amqp",
    "amqp1",
    "amqp1.0",
    "rhea",
    "rabbitmq",
    "activemq",
    "artemis",
    "qpid",
    "azure-service-bus",
    "rxjs",
    "decorator",
    "messaging",
    "pubsub",
    "dlq"
  ],
  "homepage": "https://github.com/softwarity/nestjs-amqp#readme",
  "bugs": {
    "url": "https://github.com/softwarity/nestjs-amqp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softwarity/nestjs-amqp.git"
  },
  "license": "MIT",
  "author": "François ACHACHE <francois.achache@gmail.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0 <12.0.0",
    "@nestjs/core": ">=10.0.0 <12.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.5.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "dependencies": {
    "rhea": "^3.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "bson": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
